# Paste these into Coolify's "Environment Variables" tab for this Docker
# Compose resource - not into a file in the repo. See docker-compose.coolify.yml.

# --- Required ---
JWT_SECRET=                 # openssl rand -hex 32
ANTHROPIC_API_KEY=          # console.anthropic.com
NEXT_PUBLIC_API_URL=        # public URL Coolify assigns the `backend` service, e.g. https://api.yourdomain.com
FRONTEND_ORIGIN=            # public URL of the `frontend` service, e.g. https://app.yourdomain.com

# --- Optional (sensible defaults baked into the compose file) ---
# NEXT_PUBLIC_CHAT_URL=      # only if the streaming /chat endpoint is split onto its own URL
# LLM_PROVIDER=anthropic
# ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5
# ANTHROPIC_AGENT_MODEL=claude-sonnet-4-5
# TAVILY_API_KEY=           # web_search tool; omit to leave it disabled
# DYNAMO_TABLE=assistant-platform
