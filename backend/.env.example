# --- Auth ---
JWT_SECRET=change-me-in-production

# --- LLM ---
# anthropic = Anthropic API directly (needs ANTHROPIC_API_KEY)
# bedrock   = real AWS Bedrock (needs AWS credentials + model access)
# mock      = deterministic local mock, no credentials needed
LLM_PROVIDER=mock

# Anthropic API (LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5
# ANTHROPIC_AGENT_MODEL=claude-sonnet-4-5

# AWS Bedrock (LLM_PROVIDER=bedrock)
AWS_REGION=us-east-1
BEDROCK_ROUTER_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_AGENT_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# --- Storage ---
# memory = in-process (zero setup) | dynamo = DynamoDB (local via docker or AWS)
STORE=memory
DYNAMO_TABLE=assistant-platform
# Set for DynamoDB Local (docker compose up -d); unset when deployed to AWS
# DYNAMO_ENDPOINT=http://localhost:8000

# --- Tools ---
# TAVILY_API_KEY=tvly-...

# --- HTTP ---
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# --- MCP connectors ---
# Users can connect MCP servers (Settings -> Connectors). Private/loopback URLs
# are allowed in local dev; template.yaml pins this to false when deployed (SSRF).
MCP_ALLOW_LOCAL=true
# MCP_CONNECT_TIMEOUT_MS=8000
# MCP_CALL_TIMEOUT_MS=20000
